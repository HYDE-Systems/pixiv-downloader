{
  "manifest_version": 3,
  "name": "Pixiv Download Studio 連携",
  "version": "0.1.0",
  "description": "開いているpixivの作品・作家ページを一括でダウンロードキューに送ります。",
  "permissions": ["tabs", "storage", "contextMenus", "notifications"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Pixiv Download Studio",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
