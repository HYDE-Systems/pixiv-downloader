# ダッシュボードの公開ポート（既定: 8080）
DASHBOARD_PORT=8080

# コンテナの再起動ポリシー（no / on-failure / always / unless-stopped）
# 既定: unless-stopped（手動停止以外は常に再起動）
RESTART_POLICY=unless-stopped

# 任意：設定の暗号鍵をこのパスフレーズから導出します。
# 指定しない場合、暗号鍵は永続ボリューム内に自動生成・保管されます。
# 指定するとボリューム上に平文の鍵を置かずに済み、より安全です。
# MASTER_PASSWORD=your-strong-passphrase

# 注意: pixivのrefresh_tokenやSMB認証情報は .env ではなく
#       ダッシュボード内で設定します（暗号化して保存されます）。
